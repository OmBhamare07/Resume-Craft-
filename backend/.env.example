# Server
PORT=3000
FRONTEND_URL=http://YOUR_EC2_IP:3000

# AWS
AWS_REGION=us-east-1

# Auth - make this a long random string
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Gmail (for email verification)
# Use an App Password, NOT your real Gmail password
# Enable at: myaccount.google.com/apppasswords
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
